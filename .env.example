ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic"
ANTHROPIC_AUTH_TOKEN=""
ANTHROPIC_MODEL="GLM-4.6"

# Optional override for LangGraph loop steps.
# If omitted, the runtime uses a model-aware default:
# - DeepSeek-V3.2 (`deepseek-chat` / `deepseek-reasoner`): 96
# - Others: 40
CTF_MAX_STEPS="96"

# Official hackathon MCP configuration.
# Priority: PENTEST_MCP_URL > PENTEST_MCP_SERVER_HOST
# Example:
# PENTEST_MCP_SERVER_HOST="127.0.0.1:8080"
# PENTEST_MCP_URL="http://127.0.0.1:8080/mcp"
PENTEST_MCP_SERVER_HOST=""
PENTEST_MCP_URL=""
PENTEST_AGENT_TOKEN=""
